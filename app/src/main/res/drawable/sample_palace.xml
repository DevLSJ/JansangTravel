    android:viewportWidth="400"
    android:viewportHeight="200">

    <!-- Amethyst Sunset Sky Gradient -->
    <path android:pathData="M0,0 h400 v200 h-400 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="200"
                android:startY="0"
                android:endX="200"
                android:endY="200"
                android:type="linear">
                <item android:offset="0.0" android:color="#F3E5F5" />
                <item android:offset="1.0" android:color="#E1BEE7" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Yellow/Golden Lantern Moon -->
    <path
        android:fillColor="#FFF59D"
        android:pathData="M310,60 A25,25 0,1,1 310,59.9 Z" />

    <!-- Soft Distant Hills -->
    <path android:pathData="M0,200 L80,140 Q150,165 220,150 T400,160 L400,200 Z" android:fillColor="#CE93D8" />

    <!-- Traditional Korean Palace Building Structure (Simplified architectural outline) -->
    <!-- Stone Base Platform -->
