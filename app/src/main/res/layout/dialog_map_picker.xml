<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="지도에서 추억 장소 선택"
        android:textColor="#222222"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="지도를 탭하면 선택 마커가 이동하며 좌표가 실시간으로 입력됩니다."
        android:textColor="#717171"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="#E6E6E6"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.gms.maps.MapView
                android:id="@+id/dialogMapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Floating visual helper -->
            <TextView
                android:id="@+id/tvTappedCoords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                android:background="#B3000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:text="선택된 좌표: -" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
